# Physical Environment
NODE_ENV=development
PORT=3001

# Federation (cross-jurisdiction HTTPS)
# FEDERATION_MODE: 'development' uses bearer token auth; omit or any other value uses HMAC-SHA256 (production always uses HMAC)
FEDERATION_MODE=development
# Comma-separated jurisdictions this instance owns (e.g. "US,SHARED" for the US region)
FEDERATION_JURISDICTION=US,SHARED
# JSON map of remote jurisdiction → base URL (exclude jurisdictions this instance owns)
FEDERATION_ENDPOINTS={"UK":"http://localhost:3003","EU":"http://localhost:3004"}
# Bearer token for development mode federation auth (ignored in production)
FEDERATION_DEV_TOKEN=dev-token-local
# Per-request timeout in ms (default 5000)
FEDERATION_TIMEOUT_MS=5000

# Firebase Auth
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# CORS [comma separated]
CORS_ORIGINS=http://localhost:3000,https://stencil.com,https://admin.stencil.com

# Admin Gate — shared secret required for /admin/* API routes (leave blank to disable in dev)
ADMIN_GATE_TOKEN=

# Redis Rate Limits
REDIS_URL=

# Encryption Constants
ENCRYPTION_DATABASE=encryption
ENCRYPTION_COLLECTION=__keyVault

# INTERNAL - Authority
INTERNAL_AUTHORITY_AWS_SECRETS_REGION=
INTERNAL_AUTHORITY_AWS_SECRETS_PREFIX=

# SHARED TENANT - Database
# SHARED_AUTHORITY Implied, but here for clarity
SHARED_AUTHORITY=internal
SHARED_MONGO_URI=mongodb+srv://<user>:<password>@<server-dns>.mongodb.net/?retryWrites=true&w=majority&appName=mg-stencil-next
SHARED_MONGO_DATABASE=Shared
SHARED_MONGO_MAX_POOL_SIZE=10
SHARED_MONGO_MIN_POOL_SIZE=5

# SHARED TENANT - KMS
SHARED_KMS_PROVIDER=aws

# SHARED TENANT - KMS (AWS)
SHARED_AWS_ACCESS_KEY_ID=ABC...123
SHARED_AWS_ACCESS_KEY_SECRET=dkdn....434ASDcsdf
SHARED_AWS_ACCESS_SESSION_TOKEN=
SHARED_AWS_KMS_REGION=us-east-1
SHARED_AWS_KMS_ARN=arn:aws:kms:us-east-1:123456789:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SHARED_AWS_KMS_ARN_CUSTODIAN=arn:aws:kms:us-east-1:123456789:key/yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy


# SHARED storage configuration
SHARED_STORAGE_PROVIDER=aws
SHARED_STORAGE_MAX_FILE_SIZE=10485760
SHARED_STORAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/gif,application/pdf
SHARED_STORAGE_ALLOWED_FILE_EXTENSIONS=.jpeg,.jpg,.png,.gif,.webp,.pdf,.pdfx

# SHARED AWS S3 storage
SHARED_STORAGE_AWS_REGION=us-east-1
SHARED_STORAGE_AWS_BUCKET_NAME=your-shared-storage-bucket-name
SHARED_STORAGE_AWS_CLOUDFRONT_DOMAIN=ad.....cloudfront.net
SHARED_STORAGE_AWS_CLOUDFRONT_KEY_PAIR_ID=APK...EXAMPLE
SHARED_STORAGE_AWS_CLOUDFRONT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...