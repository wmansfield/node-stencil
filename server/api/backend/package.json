{
   "name": "stencil-backend",
   "version": "1.0.0",
   "description": "Backend for Stencil application",
   "author": "",
   "private": true,
   "license": "UNLICENSED",
   "engines": {
      "node": ">=23.4.0",
      "npm": ">=10.9.0"
   },
   "scripts": {
      "build": "nest build --tsc -p tsconfig.build.json",
      "format": "prettier --write \"src/**/*.ts\"",
      "start": "nest start",
      "start:dev": "nest start --watch",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register ../node_modules/jest/bin/jest.js --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "manage-indexes": "ts-node src/scripts/manage-indexes.ts"
   },
   "dependencies": {
      "@aws-sdk/client-kms": "^3.995.0",
      "@aws-sdk/client-s3": "^3.995.0",
      "@aws-sdk/client-secrets-manager": "^3.995.0",
      "@aws-sdk/credential-providers": "^3.995.0",
      "@aws-sdk/s3-presigned-post": "^3.1003.0",
      "@aws-sdk/s3-request-presigner": "^3.995.0",
      "@azure/identity": "^4.13.0",
      "@azure/keyvault-keys": "^4.10.0",
      "@azure/storage-blob": "^12.31.0",
      "@google-cloud/storage": "^7.19.0",
      "@nestjs/common": "^11.0.0",
      "@nestjs/config": "^4.0.0",
      "@nestjs/core": "^11.0.0",
      "@nestjs/mongoose": "^11.0.4",
      "@nestjs/passport": "^11.0.5",
      "@nestjs/platform-express": "^11.0.0",
      "@nestjs/schedule": "^6.1.1",
      "@noble/hashes": "^2.0.1",
      "@willsoto/nestjs-prometheus": "^6.1.0",
      "archiver": "^7.0.1",
      "async-mutex": "^0.5.0",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.14.3",
      "compression": "^1.8.1",
      "date-fns": "^4.1.0",
      "date-fns-tz": "^3.2.0",
      "express-compression": "^1.0.2",
      "firebase-admin": "^13.6.1",
      "helmet": "^8.1.0",
      "ioredis": "^5.9.3",
      "jose": "^4.15.9",
      "lodash": "^4.17.23",
      "mongodb-client-encryption": "^7.0.0",
      "mongoose": "^9.2.1",
      "mongoose-lean-getters": "^2.3.1",
      "passport": "^0.7.0",
      "prom-client": "^15.1.3",
      "rate-limiter-flexible": "^9.1.1",
      "reflect-metadata": "^0.2.2",
      "rxjs": "^7.8.1",
      "sharp": "^0.33.5",
      "uuid": "^11.1.0"
   },
   "devDependencies": {
      "@eslint/js": "^10.0.0",
      "@nestjs/cli": "^11.0.0",
      "@nestjs/schematics": "^11.0.0",
      "@nestjs/testing": "^11.0.0",
      "@types/archiver": "^7.0.0",
      "@types/compression": "^1.8.1",
      "@types/express": "^5.0.0",
      "@types/jest": "^29.5.14",
      "@types/lodash": "^4.17.23",
      "@types/node": "^22.0.0",
      "@types/supertest": "^6.0.0",
      "eslint": "^10.0.0",
      "eslint-config-prettier": "^10.0.0",
      "jest": "^29.7.0",
      "mongodb-memory-server": "^11.0.1",
      "prettier": "^3.8.1",
      "source-map-support": "^0.5.21",
      "supertest": "^7.0.0",
      "ts-jest": "^29.4.6",
      "ts-loader": "^9.5.4",
      "ts-node": "^10.9.1",
      "tsconfig-paths": "^4.2.0",
      "typescript": "^5.9.3",
      "typescript-eslint": "^8.0.0"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "./coverage",
      "testEnvironment": "node",
      "preset": "ts-jest",
      "moduleNameMapper": {
         "^src/(.*)$": "<rootDir>/$1"
      }
   },
   "overrides": {
      "uuid": "^13.0.0"
   }
}
