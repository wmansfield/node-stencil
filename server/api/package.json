{
   "name": "stencil",
   "version": "1.0.0",
   "private": true,
   "workspaces": [
      "frontend",
      "backend"
   ],
   "scripts": {
      "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
      "start:frontend": "npm --workspace=frontend start",
      "start:backend": "npm --workspace=backend run start:dev",
      "debug:backend": "npm --workspace=backend run start:debug",
      "install:all": "npm install",
      "build": "npm run build:frontend && npm run build:backend",
      "build:frontend": "npm --workspace=frontend run build",
      "build:backend": "npm --workspace=backend run build",
      "start:prod": "npm --workspace=backend run start:prod",
      "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
   },
   "devDependencies": {
      "@types/archiver": "^7.0.0",
      "@types/jest": "^29.5.14",
      "@types/js-cookie": "^3.0.6",
      "@types/libsodium-wrappers": "^0.7.14",
      "@types/react-modal": "^3.16.3",
      "concurrently": "^9.0.0",
      "eslint-plugin-prettier": "^5.5.5",
      "jest": "^29.7.0",
      "prettier": "^3.8.1",
      "ts-jest": "^29.4.6"
   },
   "dependencies": {
      "@aws-sdk/client-kms": "^3.995.0",
      "@aws-sdk/credential-providers": "^3.995.0",
      "@azure/identity": "^4.13.0",
      "@azure/keyvault-keys": "^4.10.0",
      "@lottiefiles/dotlottie-react": "^0.18.0",
      "@lottiefiles/lottie-types": "^1.5.0",
      "@noble/hashes": "^2.0.1",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@types/uuid": "^10.0.0",
      "archiver": "^7.0.1",
      "ioredis": "^5.9.3",
      "libsodium-wrappers": "^0.7.16",
      "lodash": "^4.17.23",
      "mongodb": "~7.0.0",
      "mongodb-client-encryption": "^7.0.0",
      "rate-limiter-flexible": "^9.1.1",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "react-scripts": "^5.0.1",
      "tailwind-merge": "^3.5.0",
      "uuid": "^13.0.0"
   }
}
