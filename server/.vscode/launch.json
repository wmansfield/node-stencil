{
   "version": "0.2.0",
   "configurations": [
      {
         "type": "node",
         "request": "attach",
         "name": "Debug NestJS",
         "port": 9229,
         "restart": true,
         "sourceMaps": true,
         "outFiles": ["${workspaceFolder}/api/backend/dist/**/*.js"],
         "preLaunchTask": "npm: start:debug"
      },
      {
         "type": "node",
         "request": "launch",
         "name": "Debug Jest (backend)",
         "runtimeExecutable": "npm",
         "runtimeArgs": ["run", "test:debug"],
         "cwd": "${workspaceFolder}/api/backend",
         "console": "integratedTerminal",
         "internalConsoleOptions": "neverOpen",
         "env": {
            "NODE_ENV": "test"
         }
      }
   ]
}
